# Spotify Integration (optional — only needed for playback sync)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Set redirect URI to http://localhost:3000/api/auth/callback in Spotify Dashboard

# Optional: override the redirect URI (defaults to request origin + /api/auth/callback)
# SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Optional: require a passphrase before starting Spotify OAuth.
# The passphrase is validated server-side and never exposed to the browser bundle.
JPLRC_LOGIN_PASSPHRASE_REQUIRED=false
JPLRC_LOGIN_PASSPHRASE=NEVERGONNAGIVEYOUUP

# Recommended in production: signs login/session cookies independently of Spotify credentials.
SESSION_SECRET=
